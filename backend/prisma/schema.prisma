generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  passwordHash    String?
  isPremium       Boolean  @default(false)
  premiumUntil    DateTime?
  stripeCustomerId String?
  stripeSubId     String?
  notificationsEnabled Boolean @default(false)
  referralCode    String? @unique
  referredByCode  String?
  loyaltyPoints   Int      @default(0)
  streakDays      Int      @default(0)
  lastTakenDate   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  medications Medication[]
  caregivers  Caregiver[]
  notificationLogs NotificationLog[]
  pushSubscriptions PushSubscription[]
  referralsMade    Referral[]    @relation("Referrer")
  referralsReceived Referral[]   @relation("Referred")
  badges           UserBadge[]
}

model Referral {
  id            String   @id @default(cuid())
  referrerId    String
  referredId    String
  code          String
  status        String   @default("pending") // pending → converted → rewarded
  rewardGiven   Boolean  @default(false)
  createdAt     DateTime @default(now())
  convertedAt   DateTime?

  referrer User @relation("Referrer", fields: [referrerId], references: [id])
  referred User @relation("Referred", fields: [referredId], references: [id])

  @@index([referrerId])
  @@index([referredId])
}

model Affiliate {
  id            String   @id @default(cuid())
  userId        String
  affiliateCode String   @unique
  clickCount    Int      @default(0)
  signupCount   Int      @default(0)
  paidCount     Int      @default(0)
  totalEarnings Float    @default(0)
  pendingEarnings Float  @default(0)
  payoutEmail   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clicks  AffiliateClick[]
  conversions AffiliateConversion[]
}

model AffiliateClick {
  id           String   @id @default(cuid())
  affiliateId  String
  ipHash       String?
  userAgent    String?
  createdAt    DateTime @default(now())

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  @@index([affiliateId])
}

model AffiliateConversion {
  id           String   @id @default(cuid())
  affiliateId  String
  userId       String
  amount       Float    // commission for this conversion
  status       String   @default("pending") // pending → paid
  createdAt    DateTime @default(now())
  paidAt       DateTime?

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  @@index([affiliateId])
}

model Badge {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String   // emoji
  threshold   Int      // points or days needed
  type        String   @default("streak") // streak, points, special

  users UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  keys      String   // JSON string: { p256dh, auth }
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
}

model Medication {
  id        String   @id @default(cuid())
  userId    String
  name      String
  dose      String
  time      String
  taken     Boolean  @default(false)
  takenAt   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Caregiver {
  id          String   @id @default(cuid())
  userId      String
  name        String
  phone       String?
  email       String?
  notifySms   Boolean  @default(false)
  notifyEmail Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model NotificationLog {
  id        String   @id @default(cuid())
  userId    String
  medId     String?
  medName   String
  scheduledFor DateTime
  sentAt    DateTime?
  status    String   @default("pending")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, scheduledFor])
}

model EmailQueue {
  id           String    @id @default(cuid())
  userId       String?
  email        String
  template     String
  payload      String    // JSON
  scheduledFor DateTime
  sentAt       DateTime?
  error        String?
  attempts     Int       @default(0)
  createdAt    DateTime  @default(now())

  @@index([scheduledFor, sentAt])
}
